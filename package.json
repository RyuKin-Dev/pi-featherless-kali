{
    "name": "@earendil-works/pi-featherless-kali",
    "version": "1.0.0",
    "description": "Featherless Provider for Pi with accurate tokenization and concurrency tracking.",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "bench": "npx tsx bench/run-terminal-bench.ts",
        "bench:fast": "npx tsx bench/run-terminal-bench.ts --fast",
        "bench:quick": "npx tsx bench/run-terminal-bench.ts --quick",
        "bench:full": "npx tsx bench/run-terminal-bench.ts"
    },
    "keywords": [
        "pi",
        "pi-package",
        "coding-agent",
        "extension",
        "provider",
        "featherless",
        "llm"
    ],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.33.0",
    "peerDependencies": {
        "@earendil-works/pi-ai": "*",
        "@earendil-works/pi-coding-agent": "*",
        "@sinclair/typebox": "*"
    },
    "pi": {
        "extensions": [
            "extensions/**/*.ts"
        ],
        "skills": [
            "skills/**/SKILL.md"
        ]
    },
    "dependencies": {
        "JSONStream": "^1.3.5",
        "openai": "^6.33.0",
        "puppeteer": "^24.40.0"
    },
    "devDependencies": {
        "@earendil-works/pi-ai": "^0.80.2",
        "@earendil-works/pi-coding-agent": "^0.80.2",
        "@vitest/ui": "^4.1.3",
        "dotenv": "^17.4.1",
        "tsx": "^4.19.0",
        "typescript": "^5.8.0",
        "vitest": "^4.1.3"
    }
}
